@model FoodSafetyInspectionTracker.Models.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<h1>Dashboard</h1>

<form asp-action="Index" method="get" class="mb-4">
    <div class="row g-2">
        <div class="col-md-4">
            <select name="town" class="form-select">
                <option value="">All Towns</option>
                @foreach (var item in Model.Towns)
                {
                    if (Model.SelectedTown == item)
                    {
                        <option value="@item" selected>@item</option>
                    }
                    else
                    {
                        <option value="@item">@item</option>
                    }
                }
            </select>
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-primary">Filter</button>
        </div>
    </div>
</form>

<div class="row mb-4">
    <div class="col-md-3">
        <div class="card p-3">
            <h5>Total Premises</h5>
            <p class="fs-4">@Model.TotalPremises</p>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card p-3">
            <h5>Total Inspections</h5>
            <p class="fs-4">@Model.TotalInspections</p>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card p-3">
            <h5>Open Follow-Ups</h5>
            <p class="fs-4">@Model.OpenFollowUps</p>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card p-3">
            <h5>Overdue Follow-Ups</h5>
            <p class="fs-4">@Model.OverdueFollowUps</p>
        </div>
    </div>
</div>

<h3>Recent Inspections</h3>

<table class="table">
    <thead>
        <tr>
            <th>Premises</th>
            <th>Date</th>
            <th>Score</th>
            <th>Outcome</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var inspection in Model.RecentInspections)
        {
            <tr>
                <td>@(inspection.Premises?.Name ?? "")</td>
                <td>@inspection.InspectionDate</td>
                <td>@inspection.Score</td>
                <td>@inspection.Outcome</td>
            </tr>
        }
    </tbody>
</table>