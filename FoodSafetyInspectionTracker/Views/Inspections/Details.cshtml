@model FoodSafetyInspectionTracker.Models.Inspection

@{
    ViewData["Title"] = "Inspection Details";
}

<h1>Inspection Details</h1>

<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Premises</dt>
        <dd class="col-sm-10">
            @(Model.Premises != null ? Model.Premises.Name : "Not available")
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.InspectionDate)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.InspectionDate)
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Score)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Score)
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Outcome)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Outcome)
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Notes)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Notes)
        </dd>
    </dl>
</div>

<div>
    <a asp-action="Edit" asp-route-id="@Model.Id">Edit</a> |
    <a asp-action="Index">Back to List</a>
</div>